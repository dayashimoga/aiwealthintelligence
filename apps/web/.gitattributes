# Force LF for all source files so dart format on Linux CI is idempotent.
# Without this, Windows git converts LF→CRLF on checkout and CI always
# reports formatting changes.
* text=auto eol=lf

# Dart source
*.dart    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
*.gradle  text eol=lf
*.kt      text eol=lf
*.java    text eol=lf
*.xml     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.ts      text eol=lf

# Binary — never touch line endings
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.apk     binary
*.aab     binary
*.ipa     binary
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
*.zip     binary
*.tar.gz  binary
