<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for WealthAI Android app.
  - Enforces HTTPS for all traffic in release builds.
  - Allows cleartext only for localhost during development.
  - Enables certificate transparency for added security.
-->
<network-security-config>
    <!-- Trust system CAs for all domains by default (HTTPS only) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow HTTP to localhost for local development / emulator testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
