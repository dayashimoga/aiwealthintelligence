# Environment Configuration
# Copy this file to .env and fill in your values

# ========================
# Application
# ========================
APP_NAME=WealthAI
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
APP_LOG_LEVEL=INFO

# ========================
# Database
# ========================
DATABASE_URL=sqlite+aiosqlite:///./data/wealthai.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/wealthai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ========================
# Redis
# ========================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ========================
# Authentication
# ========================
JWT_SECRET_KEY=change-me-to-another-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ========================
# AI Provider
# ========================
AI_PROVIDER=openai
# Options: openai, groq, ollama, anthropic
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ========================
# Cloudflare
# ========================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_R2_BUCKET_NAME=

# ========================
# Market Data
# ========================
MARKET_DATA_PROVIDER=yahoo
# Options: yahoo, alpha_vantage, polygon
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=

# ========================
# Observability
# ========================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=wealthai-api
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ========================
# CORS
# ========================
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5000
CORS_ALLOW_CREDENTIALS=true

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ========================
# Email (for notifications)
# ========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@wealthai.app
